# NetSuite — OAuth 1.0a Token-Based Authentication
# Found in: NetSuite > Setup > Integration > Manage Integrations
NETSUITE_ACCOUNT_ID=3550424
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=

# NetSuite — Token-Based Auth (TBA)
# Found in: NetSuite > Setup > Users/Roles > Access Tokens
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# ClickUp
# Found in: ClickUp > Settings > Apps > API Token
CLICKUP_API_TOKEN=
# Found in: ClickUp workspace URL or API call to /team
CLICKUP_TEAM_ID=

# Anthropic (AI Insights panel)
# Found in: console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Authentication (NextAuth + Google OAuth) ─────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Required in production (your Vercel app URL)
AUTH_URL=https://your-app.vercel.app

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# → OAuth 2.0 Client ID (Web application)
# → Authorised redirect URI: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: restrict login to a specific email domain (e.g. cebasolutions.com)
# Leave blank to allow any Google account
AUTH_ALLOWED_DOMAIN=

# ─── Supabase (session + token storage) ──────────────────────────────────────
# Found in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Required for Customer Portal (public — safe to expose in browser bundles)
# NEXT_PUBLIC_SUPABASE_URL is the same value as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Found in: Supabase Dashboard > Project Settings > API > anon/public key
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
